{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://startupengineering.io/schemas/phase-frontmatter.schema.json",
  "title": "PhaseFrontmatter",
  "type": "object",
  "required": ["title", "slug", "phase_number", "short_description"],
  "properties": {
    "title": { "type": "string" },
    "slug": { "type": "string" },
    "phase_number": { "type": "integer", "minimum": 1, "maximum": 6 },
    "short_description": { "type": "string", "maxLength": 200 },
    "audience": { "type": "array", "items": { "type": "string" } }
  }
}
