{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://startupengineering.io/schemas/topic-frontmatter.schema.json",
  "title": "TopicFrontmatter",
  "type": "object",
  "required": ["title", "slug", "phase", "last_updated"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "phase": {
      "type": "string",
      "enum": ["define", "discover", "design", "develop", "validate", "operate", "agentic-engineering"]
    },
    "sub_area": { "type": ["string", "null"] },
    "audience": { "type": "array", "items": { "type": "string" } },
    "stage": {
      "type": "array",
      "items": { "enum": ["pre-seed", "seed", "series-a", "post-pmf"] }
    },
    "read_time_minutes": { "type": "integer", "minimum": 1 },
    "last_updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
