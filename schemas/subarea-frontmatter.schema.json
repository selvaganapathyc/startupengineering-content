{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://startupengineering.io/schemas/subarea-frontmatter.schema.json",
  "title": "SubareaFrontmatter",
  "type": "object",
  "required": ["title", "slug", "parent_phase", "short_description"],
  "properties": {
    "title": { "type": "string" },
    "slug": { "type": "string" },
    "parent_phase": {
      "type": "string",
      "enum": ["define", "discover", "design", "develop", "validate", "operate"]
    },
    "short_description": { "type": "string", "maxLength": 200 }
  }
}
